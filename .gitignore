# Local debug captures: emulator screenshots/uidumps, deploy tarballs,
# logcat tails, anything we scribble during a session. Should never be
# committed; the F1 cleanup also globally ignores any `tmp_<name>` file
# (e.g. credential drops like tmp_aliyun_key). If you need to keep one
# of these for evidence, copy it under docs/evidence/ which is tracked.
tmp-*
tmp_*
android/tmp-*

# R1.2 — designer staging dir; webp variants go to R2, not git
ops/skins-staging/**/*.webp
ops/skins-staging/**/*.png
ops/skins-staging/**/*.jpg

android/ui-*.xml
