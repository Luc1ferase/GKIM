# Backend-only PostgreSQL inputs. Keep real values in an untracked `.env.local`
# or deployment secret manager; do not package them into the Android client.
PGHOST="124.222.15.128"
PGPORT="5432"
PGUSER="postgres"
PGPASSWORD="<set-in-local-secret-store>"
PGDATABASE="<set-database-name>"
PGSSLMODE="<set-after-ops-confirms-disable-or-require>"
PGSSLROOTCERT="<optional-backend-only-ca-path>"

# Optional DSN for tooling that prefers a single connection variable.
DATABASE_URL="postgres://postgres:<set-in-local-secret-store>@124.222.15.128:5432/<set-database-name>"

# Cloudflare R2 — companion-skin asset bucket (companion-skin-gacha §R1.x).
# Mint the access key in Dashboard → R2 → Manage R2 API Tokens (Object Read &
# Write, scoped to bucket: gkim-assets, no TTL). The secret is shown once.
R2_GKIM_ASSETS_ACCESS_KEY_ID="<set-in-local-secret-store>"
R2_GKIM_ASSETS_SECRET="<set-in-local-secret-store>"
R2_GKIM_ASSETS_ACCOUNT_ID="0657f704324c11ff98c0fb64db9f10af"
R2_GKIM_ASSETS_ENDPOINT="https://0657f704324c11ff98c0fb64db9f10af.r2.cloudflarestorage.com"
R2_GKIM_ASSETS_BUCKET="gkim-assets"
R2_GKIM_ASSETS_PUBLIC_HOST="cdn.lastxuans.sbs"
