# Backend-only PostgreSQL inputs. Keep real values in an untracked `.env.local`
# or deployment secret manager; do not package them into the Android client.
PGHOST="124.222.15.128"
PGPORT="5432"
PGUSER="postgres"
PGPASSWORD="<set-in-local-secret-store>"
PGDATABASE="<set-database-name>"
PGSSLMODE="<set-after-ops-confirms-disable-or-require>"
PGSSLROOTCERT="<optional-backend-only-ca-path>"

# Optional DSN for tooling that prefers a single connection variable.
DATABASE_URL="postgres://postgres:<set-in-local-secret-store>@124.222.15.128:5432/<set-database-name>"
