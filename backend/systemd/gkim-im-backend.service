[Unit]
Description=GKIM IM Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/gkim-im/backend
EnvironmentFile=/etc/gkim-im-backend/gkim-im-backend.env
ExecStart=/opt/gkim-im/backend/target/release/gkim-im-backend
Restart=on-failure
RestartSec=5
Environment=RUST_BACKTRACE=1
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
