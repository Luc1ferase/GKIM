# Copy this file to an untracked `backend/.env.local` for local smoke tests,
# or to `/etc/gkim-im-backend/gkim-im-backend.env` on Ubuntu.
# Never commit filled-in passwords or live DSNs.

APP_SERVICE_NAME=gkim-im-backend
APP_BIND_ADDR=0.0.0.0:8080
APP_LOG_FILTER=info

PGHOST=124.222.15.128
PGPORT=5432
PGUSER=postgres
PGPASSWORD=<set in untracked .env.local or deployment secret>
PGDATABASE=<set target database name>
PGSSLMODE=<set only if operations requires TLS>
PGSSLROOTCERT=<optional absolute path such as /opt/gkim-im/certs/postgres-ca.pem>

# Optional DSN override for tooling that prefers a single connection string.
# DATABASE_URL=postgres://postgres:<password>@124.222.15.128:5432/<database>?sslmode=disable
